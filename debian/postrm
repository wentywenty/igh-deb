#!/bin/bash
set -e

# Prevent execution on host during build stage
if [ "${HOST_BUILD_STAGE:-0}" -eq 1 ]; then
    exit 0
fi

KERNEL_VER=$(uname -r)

# Update module dependencies
# Use -F if System.map exists, otherwise run depmod -a
if [ -f "/boot/System.map-$KERNEL_VER" ]; then
    depmod -F "/boot/System.map-$KERNEL_VER" "$KERNEL_VER"
else
    depmod -a "$KERNEL_VER"
fi

# Remove PATH configuration on purge
if [ "$1" = "purge" ] || [ "$1" = "remove" ]; then
    PROFILE_FILE="/etc/profile.d/ethercat.sh"
    if [ -f "$PROFILE_FILE" ]; then
        echo "Removing EtherCAT PATH configuration..."
        rm -f "$PROFILE_FILE"
    fi

    if command -v systemctl >/dev/null 2>&1 && [ -d "/run/systemd/system" ]; then
        systemctl disable --now ethercat.service >/dev/null 2>&1 || true
        systemctl disable --now ethercat-first-boot.service >/dev/null 2>&1 || true
        systemctl daemon-reload || true
        echo "Disabled ethercat.service"
        echo "Disabled ethercat-first-boot.service"
    fi
fi

# Remove first-boot marker only on purge.
if [ "$1" = "purge" ]; then
    rm -f /var/lib/ethercat/initialized
    rmdir /var/lib/ethercat 2>/dev/null || true
fi

# Refresh dynamic linker cache after package removal/purge.
if command -v ldconfig >/dev/null 2>&1; then
    ldconfig
fi

exit 0
