#!/usr/bin/make -f

export DH_VERBOSE=1

include /usr/share/dpkg/pkg-info.mk

# External environment parameters via env.sh / CI
CROSS_COMPILE ?=
DEB_HOST_ARCH ?= $(shell dpkg-architecture -qDEB_HOST_ARCH 2>/dev/null || echo amd64)
KERNEL_ARCH := $(if $(filter amd64,$(DEB_HOST_ARCH)),x86,$(if $(filter arm64,$(DEB_HOST_ARCH)),arm64,$(DEB_HOST_ARCH)))
export ARCH ?= $(KERNEL_ARCH)
export KERNEL_SRC ?= /lib/modules/$(shell uname -r)/build
export PREFIX ?= /opt/ethercat

DEB_HOST_GNU_TYPE ?= $(shell dpkg-architecture -qDEB_HOST_GNU_TYPE 2>/dev/null || echo x86_64-linux-gnu)
DEB_HOST_MULTIARCH ?= $(shell dpkg-architecture -qDEB_HOST_MULTIARCH 2>/dev/null || echo x86_64-linux-gnu)

%:
	dh $@

override_dh_auto_configure:
	@if [ ! -d "$(KERNEL_SRC)" ]; then \
		echo "ERROR: Kernel headers not found at $(KERNEL_SRC)" >&2; \
		echo "" >&2; \
		echo "DKMS needs kernel headers to compile the EtherCAT kernel modules." >&2; \
		echo "Install the matching kernel headers package, for example:" >&2; \
		echo "  Ubuntu/Debian:  apt install linux-headers-$$(uname -r)" >&2; \
		echo "  Rockchip:       apt install linux-headers-current-rockchip-rk3588" >&2; \
		echo "  Or search:      apt search linux-headers | grep $$(uname -r)" >&2; \
		exit 1; \
	fi
	cd ethercat && ./bootstrap
	dh_auto_configure -D ethercat -- \
		--host=$(DEB_HOST_GNU_TYPE) \
		--enable-kernel \
		--enable-generic \
		--enable-igb \
		--disable-eoe \
		--enable-hrtimer \
		--with-systemdsystemunitdir="/lib/systemd/system" \
		--prefix="$(PREFIX)" \
		--with-linux-dir="$(KERNEL_SRC)" \
		--sysconfdir=/etc \
		--libdir=\$${prefix}/lib/$(DEB_HOST_MULTIARCH)

override_dh_auto_build:
	dh_auto_build -D ethercat -- -j$(shell nproc)
	# DKMS source tree assembly (replaces kernel module cross-compilation)
	bash debian/assemble-dkms.sh ethercat debian/dkms-src

override_dh_auto_install:
	dh_auto_install -D ethercat -- DESTDIR=$(CURDIR)/debian/ethercat-igh

override_dh_install:
	dh_install
	
	if [ -f "debian/ethercat-igh$(PREFIX)/etc/ethercat.conf" ]; then \
		mkdir -p debian/ethercat-igh/etc; \
		mv "debian/ethercat-igh$(PREFIX)/etc/ethercat.conf" debian/ethercat-igh/etc/ethercat.conf; \
		rmdir "debian/ethercat-igh$(PREFIX)/etc" 2>/dev/null || true; \
	fi
	
	if [ -f "debian/ethercat-igh/etc/ethercat.conf" ]; then \
		sed -i 's/^MASTER0_DEVICE=""/MASTER0_DEVICE=""/' debian/ethercat-igh/etc/ethercat.conf; \
		sed -i 's/^DEVICE_MODULES=""/DEVICE_MODULES=""/' debian/ethercat-igh/etc/ethercat.conf; \
	fi

	install -D -m 755 debian/ethercat_init.sh debian/ethercat-igh/opt/ethercat/sbin/ethercat_init.sh
	install -D -m 644 debian/ethercat-first-boot.service debian/ethercat-igh/lib/systemd/system/ethercat-first-boot.service

override_dh_gencontrol:
	dh_gencontrol

override_dh_strip:
	# Stripping disabled - cross-compiled binaries need custom strip

override_dh_shlibdeps:
	# shlibdeps disabled for external toolchain builds

override_dh_dwz:
	# dwz not compatible with cross-compiled ELF

override_dh_clean:
	dh_clean
	rm -rf debian/dkms-src
